# DeepSeek online model API
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Vision model — used for image parsing
VISION_API_KEY=sk-xxx
VISION_BASE_URL=https://ai.devtool.tech/proxy/v1
VISION_MODEL=gpt-4o

# Models served locally via Ollama
OLLAMA_BASE_URL=http://localhost:11434   # change to your Ollama host
OLLAMA_CHAT_MODEL=qwen2.5:32b            # chat model
OLLAMA_REASON_MODEL=deepseek-r1:32b      # reasoning model
OLLAMA_AGENT_MODEL=qwen2.5:32b           # agent model
OLLAMA_EMBEDDING_MODEL=bge-m3            # embedding model

# Model service selection
CHAT_SERVICE=deepseek    # deepseek | ollama — picks which API key / base URL / model to load
REASON_SERVICE=ollama    # deepseek | ollama — if deepseek, set DEEPSEEK_MODEL to deepseek-reasoner
AGENT_SERVICE=deepseek   # deepseek | ollama

# SerpAPI — web search (sign up at https://serpapi.com/)
SERPAPI_KEY=xxx
SEARCH_RESULT_COUNT=10   # number of web search results to return

# Local MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=assist_gen

# Local Neo4j database
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Local Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.90   # cache similarity threshold

# Microsoft GraphRAG
GRAPHRAG_PROJECT_DIR=/path/to/llm_backend/app/graphrag   # GraphRAG project directory
GRAPHRAG_DATA_DIR=data                  # data directory name
GRAPHRAG_QUERY_TYPE=local               # local | global | drift | basic
GRAPHRAG_RESPONSE_TYPE=text             # response type
GRAPHRAG_COMMUNITY_LEVEL=3              # community level
GRAPHRAG_DYNAMIC_COMMUNITY=false        # dynamically select communities
